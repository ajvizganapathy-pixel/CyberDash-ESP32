{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PIO: Build",
      "type": "shell",
      "command": "pio run",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "PIO: Upload (Serial)",
      "type": "shell",
      "command": "pio run -t upload",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "PIO: Upload (OTA)",
      "type": "shell",
      "command": "pio run -e esp32dev-ota -t upload",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "PIO: Monitor",
      "type": "shell",
      "command": "pio device monitor"
    },
    {
      "label": "PIO: Clean",
      "type": "shell",
      "command": "pio run -t clean"
    },
    {
      "label": "PIO: Upload Filesystem",
      "type": "shell",
      "command": "pio run -t uploadfs"
    }
  ]
}
